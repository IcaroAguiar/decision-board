{
	"name": "decision-board",
	"version": "0.1.0",
	"private": true,
	"description": "Self-hostable portfolio decision dashboard for contribution planning, strategy review, and structured reports.",
	"license": "AGPL-3.0-only",
	"type": "module",
	"packageManager": "pnpm@11.0.6",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@nestjs/core",
			"@prisma/client",
			"@prisma/engines",
			"esbuild",
			"prisma"
		]
	},
	"engines": {
		"node": ">=22",
		"pnpm": ">=11.0.6 <12"
	},
	"scripts": {
		"build": "corepack pnpm -r --if-present build",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:status": "prisma migrate status",
		"db:studio": "prisma studio",
		"dev": "corepack pnpm --parallel --filter @decision-board/api --filter @decision-board/web dev",
		"format": "biome check --write .",
		"format:unsafe": "biome check --write --unsafe .",
		"lint": "biome ci .",
		"test": "corepack pnpm -r --if-present test",
		"typecheck": "corepack pnpm --filter @decision-board/types build && corepack pnpm -r --if-present typecheck"
	},
	"dependencies": {
		"@prisma/client": "6.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.5",
		"@types/node": "24.10.1",
		"prisma": "6.19.0",
		"typescript": "5.9.3"
	}
}
